rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }
    function isOwner() {
      return request.auth != null
        && exists(userDocPath())
        && get(userDocPath()).data.role == 'owner';
    }
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (request.auth.uid == userId || isOwner());
    }
    match /orders/{orderId} {
      allow create: if request.auth != null
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.customerName is string
        && request.resource.data.quantity is int
        && request.resource.data.paymentMethod is string;
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.customerId || isOwner());
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.customerId || isOwner());
    }
    match /inventory/{docId} {
      allow read, write: if request.auth != null;
    }
    match /inventoryActivity/{activityId} {
      allow read: if request.auth != null && isOwner();
      allow create: if request.auth != null;
    }
    match /meta/{docId} {
      allow read, write: if request.auth != null;
    }
    match /wallets/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /walletTransactions/{txId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }
    match /reviews/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
